# Variáveis de ambiente — SME SIGLA ALVO Testes UI

# ============================================================================
# API SIGLA — Processos Convocação
# ============================================================================
# Sem autenticação — endpoints públicos no ambiente de homologação
SIGLA_BASE_URL=https://hom-api-sigla.sme.prefeitura.sp.gov.br

# ============================================================================
# CONCURSO API — Endpoints
# ============================================================================
CONCURSO_BASE_URL=https://qa-api-sigla.sme.prefeitura.sp.gov.br

# ============================================================================
# UI SIGLA — Frontend Base URL
# ============================================================================
SIGLA_UI_BASE_URL=https://hom-sigla.sme.prefeitura.sp.gov.br

# ============================================================================
# CREDENCIAIS DE LOGIN — SIGLA UI
# ============================================================================
# IMPORTANTE: Substitua pelos valores reais fornecidos pelo time
# NUNCA commite este arquivo com credenciais reais no Git
SIGLA_LOGIN_RF=seu_rf_aqui
SIGLA_LOGIN_SENHA=sua_senha_aqui

# ============================================================================
# OBSERVAÇÕES:
# - Copie este arquivo para .env e preencha com credenciais reais
