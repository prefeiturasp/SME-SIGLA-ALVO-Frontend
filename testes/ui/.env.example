# ============================================================================
# ARQUIVO DE EXEMPLO — Copie para .env e preencha com valores reais
# ============================================================================
# Este arquivo serve como referência para criar o .env local.
# No Jenkins, as variáveis são injetadas via credencial "cypress_env_sigla"
# ============================================================================

# ── Contexto de Execução ────────────────────────────────────────────────────
CI=false

# ── API SIGLA — Base URLs (QA) ──────────────────────────────────────────────
# Sem autenticação — endpoints públicos no ambiente de QA
SIGLA_BASE_URL=https://qa-api-sigla.sme.prefeitura.sp.gov.br
CONCURSO_BASE_URL=https://qa-api-sigla.sme.prefeitura.sp.gov.br
ESCOLHA_BASE_URL=https://qa-api-sigla.sme.prefeitura.sp.gov.br
IMPORTA_BASE_URL=https://qa-api-sigla.sme.prefeitura.sp.gov.br

# ── UI SIGLA — Frontend (QA) ────────────────────────────────────────────────
SIGLA_UI_BASE_URL=https://qa-sigla.sme.prefeitura.sp.gov.br
CYPRESS_BASE_URL=https://qa-sigla.sme.prefeitura.sp.gov.br

# ── Credenciais de Login — Perfil Administrador ─────────────────────────────
SIGLA_LOGIN_RF=007001
SIGLA_LOGIN_SENHA=Alvo123@

# ── Credenciais de Login — Perfil Visualização (Somente Leitura) ────────────
SIGLA_LOGIN_RF_VISUALIZACAO=007005
SIGLA_LOGIN_SENHA_VISUALIZACAO=Alvo123@

# ── Cypress Cloud (Sorry-Cypress Dashboard) ─────────────────────────────────
# Configurado automaticamente no Jenkinsfile
# CYPRESS_CLOUD_KEY=somekey
# CYPRESS_CLOUD_RUN_ID=SME-SIGLA_JENKINS-BUILD-${BUILD_NUMBER}

# ============================================================================
# OBSERVAÇÕES:
# - Copie este arquivo para .env e preencha com credenciais reais
# - O arquivo .env está no .gitignore e NÃO será versionado
# - Em CI/CD, use a credencial "cypress_env_sigla" no Jenkins
# - Para outros ambientes, ajuste as URLs conforme necessário
# ============================================================================
